{
  "cli": {
    "version": ">= 14.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SUPABASE_ENABLED": "false"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_SUPABASE_ENABLED": "true",
        "EXPO_PUBLIC_SUPABASE_URL": "",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "",
        "EXPO_PUBLIC_OPENAI_API_KEY": ""
      }
    }
  },
  "submit": {
    "production": {}
  }
}
